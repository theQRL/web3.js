{
	"name": "@theqrl/web3-plugin-example",
	"version": "0.5.0",
	"publishConfig": {
		"access": "public"
	},
	"description": "Example implementations of Web3.js' plugin system",
	"main": "./lib/index.js",
	"types": "./lib/index.d.ts",
	"repository": {
		"type": "git",
		"url": "https://github.com/theQRL/web3.js",
		"directory": "tools/web3-plugin-example"
	},
	"engines": {
		"node": ">=20"
	},
	"author": "The QRL Contributors",
	"license": "LGPL-3.0",
	"keywords": [
		"QRL",
		"JavaScript",
		"API"
	],
	"files": [
		"lib/**/*",
		"src/**/*"
	],
	"scripts": {
		"clean": "rimraf dist && rimraf lib",
		"prebuild": "pnpm run clean",
		"build": "tsc --build",
		"build:check": "node -e \"require('./lib')\"",
		"lint": "eslint .",
		"lint:fix": "eslint --fix .",
		"format": "prettier --write '**/*'",
		"test": "jest --config=./test/unit/jest.config.js",
		"test:coverage:unit": "jest --config=./test/unit/jest.config.js --coverage=true",
		"test:ci": "jest --coverage=true --coverage-reporters=json --verbose",
		"test:watch": "pnpm run test -- --watch",
		"test:unit": "jest --config=./test/unit/jest.config.js"
	},
	"devDependencies": {
		"@theqrl/eslint-config-base-web3": "workspace:^",
		"@theqrl/web3": "workspace:^",
		"@theqrl/web3-core": "workspace:^",
		"@theqrl/web3-qrl-abi": "workspace:^",
		"@theqrl/web3-qrl-contract": "workspace:^",
		"@theqrl/web3-types": "workspace:^",
		"@theqrl/web3-utils": "workspace:^",
		"@types/jest": "30.0.0",
		"@typescript-eslint/eslint-plugin": "8.59.2",
		"@typescript-eslint/parser": "8.59.2",
		"eslint": "10.3.0",
		"eslint-config-prettier": "10.1.8",
		"jest": "30.4.2",
		"jest-extended": "7.0.0",
		"prettier": "3.8.3",
		"ts-jest": "29.4.9",
		"typescript": "6.0.3"
	},
	"peerDependencies": {
		"@theqrl/web3-core": "workspace:^",
		"@theqrl/web3-qrl-abi": "workspace:^",
		"@theqrl/web3-qrl-contract": "workspace:^",
		"@theqrl/web3-types": "workspace:^",
		"@theqrl/web3-utils": "workspace:^"
	}
}
