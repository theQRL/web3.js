{
	"name": "@theqrl/web3-plugin-example",
	"version": "0.4.0",
	"publishConfig": {
		"access": "public"
	},
	"description": "Example implementations of Web3.js' plugin system",
	"main": "./lib/index.js",
	"types": "./lib/index.d.ts",
	"repository": {
		"type": "git",
		"url": "https://github.com/theQRL/web3.js",
		"directory": "tools/web3-plugin-example"
	},
	"engines": {
		"node": ">=20"
	},
	"author": "The QRL Contributors",
	"license": "LGPL-3.0",
	"keywords": [
		"QRL",
		"JavaScript",
		"API"
	],
	"files": [
		"lib/**/*",
		"src/**/*"
	],
	"scripts": {
		"clean": "rimraf dist && rimraf lib",
		"prebuild": "pnpm run clean",
		"build": "tsc --build",
		"build:check": "node -e \"require('./lib')\"",
		"lint": "eslint .",
		"lint:fix": "eslint --fix .",
		"format": "prettier --write '**/*'",
		"test": "jest --config=./test/unit/jest.config.js",
		"test:coverage:unit": "jest --config=./test/unit/jest.config.js --coverage=true",
		"test:ci": "jest --coverage=true --coverage-reporters=json --verbose",
		"test:watch": "pnpm run test -- --watch",
		"test:unit": "jest --config=./test/unit/jest.config.js"
	},
	"devDependencies": {
		"@theqrl/eslint-config-base-web3": "^0.4.0",
		"@theqrl/web3": "^0.4.0",
		"@theqrl/web3-core": "^0.4.0",
		"@theqrl/web3-qrl-abi": "^0.4.0",
		"@theqrl/web3-qrl-contract": "^0.4.0",
		"@theqrl/web3-types": "^0.4.0",
		"@theqrl/web3-utils": "^0.4.0",
		"@types/jest": "^30.0.0",
		"@typescript-eslint/eslint-plugin": "^8.59.0",
		"@typescript-eslint/parser": "^8.59.0",
		"eslint": "^10.2.1",
		"eslint-config-prettier": "^10.1.8",
		"jest": "^30.3.0",
		"jest-extended": "^7.0.0",
		"prettier": "^3.8.3",
		"ts-jest": "^29.1.0",
		"typescript": "^6.0.3"
	},
	"peerDependencies": {
		"@theqrl/web3-core": "^0.4.0",
		"@theqrl/web3-qrl-abi": "^0.4.0",
		"@theqrl/web3-qrl-contract": "^0.4.0",
		"@theqrl/web3-types": "^0.4.0",
		"@theqrl/web3-utils": "^0.4.0"
	}
}
