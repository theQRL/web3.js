{
	"name": "@theqrl/web3-qrl",
	"version": "0.5.0",
	"publishConfig": {
		"access": "public"
	},
	"description": "Web3 module to interact with the QRL blockchain and smart contracts.",
	"main": "./lib/commonjs/index.js",
	"module": "./lib/esm/index.js",
	"exports": {
		".": {
			"types": "./lib/types/index.d.ts",
			"import": "./lib/esm/index.js",
			"require": "./lib/commonjs/index.js"
		}
	},
	"repository": {
		"type": "git",
		"url": "https://github.com/theQRL/web3.js",
		"directory": "packages/web3-qrl"
	},
	"author": "The QRL Contributors",
	"license": "LGPL-3.0",
	"engines": {
		"node": ">=20"
	},
	"files": [
		"lib/**/*",
		"src/**/*"
	],
	"scripts": {
		"clean": "rimraf dist && rimraf lib",
		"prebuild": "pnpm run clean",
		"build": "pnpm run build:cjs && pnpm run build:esm && pnpm run build:types",
		"build:cjs": "tsc --build tsconfig.cjs.json && echo '{\"type\": \"commonjs\"}' > ./lib/commonjs/package.json",
		"build:esm": "tsc --build tsconfig.esm.json && echo '{\"type\": \"module\"}' > ./lib/esm/package.json",
		"build:types": "tsc --build tsconfig.types.json",
		"build:check": "node -e \"require('./lib')\"",
		"lint": "eslint .",
		"lint:fix": "eslint --fix .",
		"format": "prettier --write '**/*'",
		"test": "jest --config=./test/unit/jest.config.js",
		"test:coverage:unit": "jest --config=./test/unit/jest.config.js --coverage=true",
		"test:ci": "jest --coverage=true --coverage-reporters=json --verbose",
		"test:e2e:mainnet": "jest --config=./test/e2e/jest.config.js --forceExit",
		"test:watch": "pnpm run test -- --watch",
		"test:unit": "jest --config=./test/unit/jest.config.js",
		"test:integration": "jest --config=./test/integration/jest.config.js --runInBand --forceExit",
		"test:coverage:integration": "jest --config=./test/integration/jest.config.js --runInBand --forceExit --coverage=true",
		"test:e2e:electron": "pnpm exec cypress run --headless --browser electron",
		"test:e2e:chrome": "pnpm exec cypress run --headless --browser chrome",
		"test:e2e:firefox": "pnpm exec cypress run --headless --browser firefox"
	},
	"devDependencies": {
		"@theqrl/eslint-config-base-web3": "workspace:^",
		"@theqrl/web3-providers-http": "workspace:^",
		"@types/jest": "30.0.0",
		"@typescript-eslint/eslint-plugin": "8.59.2",
		"@typescript-eslint/parser": "8.59.2",
		"eslint": "10.3.0",
		"eslint-config-prettier": "10.1.8",
		"jest": "30.4.2",
		"jest-extended": "7.0.0",
		"prettier": "3.8.3",
		"ts-jest": "29.4.9",
		"typescript": "6.0.3"
	},
	"dependencies": {
		"@theqrl/wallet.js": "2.0.2",
		"@theqrl/web3-core": "workspace:^",
		"@theqrl/web3-errors": "workspace:^",
		"@theqrl/web3-net": "workspace:^",
		"@theqrl/web3-providers-ws": "workspace:^",
		"@theqrl/web3-qrl-abi": "workspace:^",
		"@theqrl/web3-qrl-accounts": "workspace:^",
		"@theqrl/web3-rpc-methods": "workspace:^",
		"@theqrl/web3-types": "workspace:^",
		"@theqrl/web3-utils": "workspace:^",
		"@theqrl/web3-validator": "workspace:^",
		"setimmediate": "1.0.5"
	}
}
